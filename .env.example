# Google Gemini API Key
GOOGLE_API_KEY=your_gemini_api_key_here

# Firebase Configuration (Service Account JSON path or content)
# For local dev, place your serviceAccountKey.json in /backend/
# For deployment, you can set this as an environment variable
FIREBASE_SERVICE_ACCOUNT_JSON=./serviceAccountKey.json

# Frontend Configuration
VITE_FIREBASE_API_KEY=your_frontend_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
